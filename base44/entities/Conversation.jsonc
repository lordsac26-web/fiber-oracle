{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "agent_id": {
      "type": "string",
      "description": "Agent conversation ID from the agent system",
      "index": true
    },
    "agent_name": {
      "type": "string",
      "description": "Name of the agent"
    },
    "title": {
      "type": "string",
      "description": "Conversation title"
    },
    "message_count": {
      "type": "number",
      "description": "Number of messages in conversation"
    },
    "is_archived": {
      "type": "boolean",
      "default": false,
      "description": "Whether conversation is archived",
      "index": true
    },
    "archive_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date when conversation will be permanently deleted"
    },
    "archived_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the conversation was archived"
    }
  },
  "required": [
    "agent_id",
    "agent_name"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}